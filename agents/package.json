{
  "name": "@falco/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:market-ops": "tsx --env-file=.env src/market_ops.ts",
    "dev:trader":     "tsx --env-file=.env src/trader.ts",
    "dev:risk-lp":    "tsx --env-file=.env src/risk_lp.ts",
    "dev:all": "concurrently \"pnpm dev:market-ops\" \"pnpm dev:trader\" \"pnpm dev:risk-lp\""
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
